OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSCRIBE_LANGUAGE=zh
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# 销售问答的意图识别兜底模型（规则匹配失败时调用，需要支持 JSON 模式的小模型即可）
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_INTENT_TIMEOUT=10
# 统一业务路由模型（需要支持 JSON 模式）
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_ROUTER_TIMEOUT=10
# Tavily 联网搜索
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT=10
REQUESTS_PER_MINUTE=30
MAX_AUDIO_BYTES=15728640
BACKEND_CORS_ORIGINS=*
# Docker Compose 中 Nginx 对外暴露的 HTTP 端口；不填默认 80
HTTP_PORT=80

# SQL Server (零售业务数据库，用于销售问答工具)
# 格式：host 或 host,port；端口含在 host 中时用英文逗号分隔
SQL_SERVER_HOST_NAME=
SQL_SERVER_USER_NAME=
SQL_SERVER_USER_PASSWORD=
SQL_SERVER_DATABASE=
SQL_SERVER_SCHEMA=dbo
# SQL Server 中文 varchar 常见为 GBK/CP936；若云端出现门店/商品名乱码，设为 CP936。
SQL_SERVER_CHARSET=UTF-8
# 是否同时 UNION 已归档的 *Freeze 表（默认 false：未做过年结时归档表为空，关掉省一次扫描）
SQL_SERVER_INCLUDE_FREEZE=false
SQL_SERVER_QUERY_TIMEOUT=30

# 登录鉴权（手机号 + 短信验证码 + JWT，不依赖数据库，用 YAML 白名单管理用户）
AUTH_ENABLED=true
# 32+ 字节随机串；启用 auth 时必填
AUTH_JWT_SECRET=
AUTH_JWT_TTL_SECONDS=2592000
AUTH_ALLOWLIST_PATH=auth/allowlist.yaml
AUTH_CODE_TTL_SECONDS=300
AUTH_CODE_RESEND_COOLDOWN=60
AUTH_CODE_MAX_ATTEMPTS=5
AUTH_SMS_HOURLY_LIMIT=5
# 非空时允许该固定验证码登录（开发/评测用，请勿在生产环境配置）
AUTH_DEV_BYPASS_CODE=

# 阿里云号码认证短信验证码（Dypnsapi 2017-05-25：SendSmsVerifyCode + CheckSmsVerifyCode）。
# 若上述 AUTH_DEV_BYPASS_CODE 未配置且阿里云凭证缺失，将拒绝发码。
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
# 使用号码认证服务赠送签名和赠送模板；TemplateParam 默认使用 {"code":"##code##"} 由阿里云生成验证码。
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_ENDPOINT=https://dypnsapi.aliyuncs.com
ALIYUN_SMS_SCHEME_NAME=
ALIYUN_SMS_COUNTRY_CODE=86
ALIYUN_SMS_CODE_LENGTH=6
ALIYUN_SMS_CODE_TYPE=1
ALIYUN_SMS_CASE_AUTH_POLICY=1
ALIYUN_SMS_TIMEOUT=10
